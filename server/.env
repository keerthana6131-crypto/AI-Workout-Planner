# ─────────────────────────────────────────────────
# MongoDB Atlas Connection String
# Go to https://cloud.mongodb.com → your cluster →
# "Connect" → "Drivers" → copy the URI, then replace
# <username>, <password>, and <dbname> below.
# ─────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fitness-planner?retryWrites=true&w=majority

# Server port
PORT=5000
